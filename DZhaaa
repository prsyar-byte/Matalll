// ===== کات =====

function updateTime(){

    const time = document.getElementById("time");

    if(!time) return;

    const now = new Date();

    time.textContent =
    String(now.getHours()).padStart(2,"0")
    + ":" +
    String(now.getMinutes()).padStart(2,"0");

}

updateTime();

setInterval(updateTime,1000);




// ===== نرخی دۆلار =====

let dollarPrice = 153900;


function showDollarPrice(){

    const price = document.getElementById("price");

    if(price){

        price.textContent =
        dollarPrice.toLocaleString()
        + " د.ع";

    }

}


showDollarPrice();




// ===== جوڵانی نرخ =====

function fakeMovePrice(){

    const change =
    Math.floor(Math.random()*200-100);

    dollarPrice += change;

    showDollarPrice();

}


setInterval(fakeMovePrice,10000);




// ===== گۆڕینی دراو =====

function convertDollar(){

    const usd = document.getElementById("usd");
    const result = document.getElementById("result");


    if(!usd || !result) return;


    const amount = Number(usd.value);


    if(!amount || amount <= 0){

        result.textContent =
        "تکایە بڕی دۆلار بنووسە";

        return;

    }


    result.textContent =
    (amount * dollarPrice / 100)
    .toLocaleString()
    + " د.ع";

}
