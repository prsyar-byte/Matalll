function applyLanguage(lang){

    const t = languages[lang];

    if(!t) return;


    const ids = {

        homeText:t.home,
        homeText2:t.home,

        chartText:t.chart,
        chartText2:t.chart,

        goldText:t.gold,
        goldText2:t.gold,

        moreText:t.more,

        settingsText:t.settings,
        settingsBoxText:t.settings,

        rateText:t.rate,

        convertText:t.convert,

        goldPriceText:t.goldPrice,

        chartBoxText:t.chartBox,

        newsText:t.news,

        alertText:t.alert,

        calculatorText:t.calculator
    };



    for(let id in ids){

        const element =
        document.getElementById(id);


        if(element){

            element.textContent = ids[id];

        }

    }

}




