document.addEventListener("DOMContentLoaded",()=>{

// Settings
const settingsBtn=document.getElementById("settingsBtn");
const settingsPage=document.getElementById("settingsPage");
const games=document.querySelector(".games");
const tabs=document.querySelector(".tabs");


settingsBtn.onclick=()=>{

if(settingsPage.style.display=="block"){

settingsPage.style.display="none";
games.style.display="grid";
tabs.style.display="flex";

}else{

settingsPage.style.display="block";
games.style.display="none";
tabs.style.display="none";

}

};


// Dark Mode
document.getElementById("darkModeBtn").onclick=()=>{

document.body.classList.toggle("dark-mode");

};


// Language
document.getElementById("languageBtn").onclick=()=>{

alert("🌐 کوردی / English / العربية");

};


// Notification
document.getElementById("notifyBtn").onclick=()=>{

alert("🔔 هیچ ئاگادارکردنەوەی نوێ نییە");

};


// Sound
let sound=true;

document.getElementById("soundBtn").onclick=()=>{

sound=!sound;

alert(sound ? "🔊 دەنگ چالاک کرا" : "🔇 دەنگ ناچالاک کرا");

};



// Games
document.querySelectorAll(".card").forEach(card=>{

card.onclick=()=>{

alert("🎮 یاری: "+card.querySelector("h3").textContent);

};

});


// Favorite
document.querySelectorAll(".heart").forEach(h=>{

h.onclick=(e)=>{

e.stopPropagation();

h.textContent=h.textContent=="♡"?"❤️":"♡";

};

});


// Search
const search=document.getElementById("search");

search.onkeyup=()=>{

let value=search.value.toLowerCase();

document.querySelectorAll(".card").forEach(card=>{

let name=card.querySelector("h3").textContent.toLowerCase();

card.style.display=name.includes(value)?"block":"none";

});

};



// Chat
const chatBtn=document.querySelector(".nav-item:nth-child(3)");
const chatPage=document.getElementById("chatPage");
const sendBtn=document.getElementById("sendBtn");
const messageInput=document.getElementById("messageInput");
const chatBox=document.getElementById("chatBox");


chatBtn.onclick=()=>{

games.style.display="none";
chatPage.style.display="block";

};


sendBtn.onclick=()=>{

let text=messageInput.value;

if(text!=""){

let p=document.createElement("p");

p.textContent="👤 "+text;

chatBox.appendChild(p);

messageInput.value="";

}

};



// Profile
const profileBtn=document.querySelector(".nav-item:nth-child(4)");
const profilePage=document.getElementById("profilePage");
const editProfileBtn=document.getElementById("editProfileBtn");
const profileName=document.querySelector("#profilePage h3");


profileBtn.onclick=()=>{

games.style.display="none";
chatPage.style.display="none";
profilePage.style.display="block";

};


// Save Name
let savedName=localStorage.getItem("username");

if(savedName){

profileName.textContent=savedName;

}


editProfileBtn.onclick=()=>{

let name=prompt("ناوی نوێ بنووسە:");

if(name){

profileName.textContent=name;

localStorage.setItem("username",name);

}

};


// Home & Games Navigation

const homeBtn = document.querySelector(".nav-item:nth-child(1)");
const gamesBtn = document.querySelector(".nav-item:nth-child(2)");

homeBtn.onclick = () => {

  games.style.display = "grid";
  tabs.style.display = "flex";

  chatPage.style.display = "none";
  profilePage.style.display = "none";
  settingsPage.style.display = "none";

};


gamesBtn.onclick = () => {

  games.style.display = "grid";
  tabs.style.display = "flex";

  chatPage.style.display = "none";
  profilePage.style.display = "none";
  settingsPage.style.display = "none";

};
    // Profile Image

const changeImageBtn = document.getElementById("changeImageBtn");
const imageInput = document.getElementById("imageInput");
const profileImage = document.getElementById("profileImage");


let savedImage = localStorage.getItem("profileImage");

if(savedImage && profileImage){
  profileImage.src = savedImage;
}


if(changeImageBtn){

changeImageBtn.onclick = ()=>{

imageInput.click();

};

}


if(imageInput){

imageInput.onchange = ()=>{

let file = imageInput.files[0];

if(file){

let reader = new FileReader();

reader.onload = function(e){

profileImage.src = e.target.result;

localStorage.setItem("profileImage", e.target.result);

}

reader.readAsDataURL(file);

}

};

}
    const scoreText = document.getElementById("score");
const winsText = document.getElementById("wins");

let score = localStorage.getItem("score") || 0;
let wins = localStorage.getItem("wins") || 0;

if(scoreText){
  scoreText.textContent = score;
}

if(winsText){
  winsText.textContent = wins;
}
    // Favorite Games Save

const favCount = document.getElementById("favCount");
const favGamesBox = document.getElementById("favGames");

let favorites = JSON.parse(localStorage.getItem("favorites")) || [];


function updateFavorites(){

  if(favCount){
    favCount.textContent = favorites.length;
  }

  if(favGamesBox){

    favGamesBox.innerHTML = "";

    favorites.forEach(game=>{

      let p = document.createElement("p");
      p.textContent = "❤️ " + game;

      favGamesBox.appendChild(p);

    });

  }

}


document.querySelectorAll(".heart").forEach(heart=>{

heart.onclick=(e)=>{

e.stopPropagation();

let card = heart.parentElement;
let name = card.querySelector("h3").textContent;


if(heart.textContent=="♡"){

heart.textContent="❤️";

favorites.push(name);

}else{

heart.textContent="♡";

favorites = favorites.filter(item=>item != name);

}


localStorage.setItem("favorites", JSON.stringify(favorites));

updateFavorites();

};

});


updateFavorites();
    // Friends Online System

const friendInput = document.getElementById("friendInput");
const addFriendBtn = document.getElementById("addFriendBtn");
const friendList = document.getElementById("friendList");

let friends = JSON.parse(localStorage.getItem("friends")) || [];


function showFriends(){

  if(friendList){

    friendList.innerHTML = "";

    friends.forEach((friend,index)=>{

      let div = document.createElement("div");

      div.className = "friend";

      div.innerHTML = `
👤 ${friend.name}
<br>
${friend.online ? "🟢 ئۆنلاین" : "⚪ ئۆفلاین"}

<br>

<button onclick="openFriendChat('${friend.name}')">
💬 چات
</button>

<button onclick="changeStatus(${index})">
🔄
</button>
`;
      friendList.appendChild(div);

    });

  }

}


// زیادکردنی هاوڕێ

if(addFriendBtn){

addFriendBtn.onclick = ()=>{

let name = friendInput.value.trim();

if(name){

friends.push({
  name:name,
  online:true
});


localStorage.setItem(
"friends",
JSON.stringify(friends)
);


friendInput.value="";

showFriends();

}

};

}


// گۆڕینی دۆخ

function changeStatus(index){

friends[index].online = !friends[index].online;

localStorage.setItem(
"friends",
JSON.stringify(friends)
);

showFriends();

}


showFriends();
    // Private Friend Chat

const privateChat = document.getElementById("privateChat");
const chatFriendName = document.getElementById("chatFriendName");
const privateChatBox = document.getElementById("privateChatBox");
const privateMessageInput = document.getElementById("privateMessageInput");
const privateSendBtn = document.getElementById("privateSendBtn");


let currentFriend = "";


function openFriendChat(name){

currentFriend = name;

chatFriendName.textContent = "👤 " + name;

privateChat.style.display="block";

loadMessages();

}


function loadMessages(){

privateChatBox.innerHTML="";

let messages = JSON.parse(
localStorage.getItem("chat_"+currentFriend)
) || [];


messages.forEach(msg=>{

let p=document.createElement("p");

p.textContent="👤 "+msg;

privateChatBox.appendChild(p);

});

}



if(privateSendBtn){

privateSendBtn.onclick=()=>{

let text=privateMessageInput.value.trim();


if(text){

let messages = JSON.parse(
localStorage.getItem("chat_"+currentFriend)
) || [];


messages.push(text);


localStorage.setItem(
"chat_"+currentFriend,
JSON.stringify(messages)
);


privateMessageInput.value="";

loadMessages();

}

};

}
  

// Signup

signupBtn.onclick = ()=>{

let user = usernameInput.value;
let pass = passwordInput.value;


if(user && pass){

localStorage.setItem(
"account",
JSON.stringify({
username:user,
password:pass
})
);


alert("✅ هەژمار دروست کرا");

loginPage.style.display="none";

}

};



// Login

loginBtn.onclick = ()=>{


let user = usernameInput.value;
let pass = passwordInput.value;


let saved = JSON.parse(
localStorage.getItem("account")
);


if(saved && user==saved.username && pass==saved.password){

alert("✅ بەخێربێیت "+user);

loginPage.style.display="none";


}else{

alert("❌ زانیاری هەڵەیە");

}

};
    // Connect Login Name With Profile

const loginName = document.getElementById("usernameInput");
const profileTitle = document.querySelector("#profilePage h3");

let accountData = JSON.parse(localStorage.getItem("account"));


if(accountData && profileTitle){

  profileTitle.textContent = accountData.username;

}


// لە کاتی دروستکردنی هەژمار ناوەکە هەڵبگرە

const oldSignup = localStorage.getItem("account");

if(oldSignup){

 let data = JSON.parse(oldSignup);

 if(profileTitle){
   profileTitle.textContent = data.username;
 }

}
});